# BDS Platform HCM — .gitignore

# ─── SECRETS (QUAN TRỌNG NHẤT) ────────────────────────────────
.env
.env.local
.env.*.local
*.key
*.pem

# ─── DEPENDENCIES ─────────────────────────────────────────────
node_modules/
.npm/

# ─── BUILD OUTPUT ─────────────────────────────────────────────
dist/
build/
.vercel/
.next/

# ─── SUPABASE LOCAL ───────────────────────────────────────────
.supabase/

# ─── MACOS ────────────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride

# ─── VSCODE ───────────────────────────────────────────────────
.vscode/settings.json
.vscode/launch.json
# Giữ lại .vscode/extensions.json để share recommended extensions

# ─── LOGS ────────────────────────────────────────────────────
*.log
npm-debug.log*

# ─── TEMP ────────────────────────────────────────────────────
*.tmp
*.temp
.cache/
