# .env.example
# BDS Platform HCM — Template biến môi trường
# Sao chép file này thành .env.local và điền thông tin thật
# TUYỆT ĐỐI KHÔNG commit .env.local lên Git

# ─── SUPABASE ─────────────────────────────────────────────────
SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
SUPABASE_ANON_KEY=eyJ...                  # Lấy từ: Settings → API → anon key
SUPABASE_SERVICE_KEY=eyJ...               # Lấy từ: Settings → API → service_role key (CHỈ dùng trong Edge Functions)

# ─── GOOGLE APIS ──────────────────────────────────────────────
GOOGLE_MAPS_KEY=AIza...                   # Hạn chế domain trong GCP Console
GOOGLE_PLACES_KEY=AIza...                 # Thường dùng chung 1 key với Maps

# ─── AI ───────────────────────────────────────────────────────
CLAUDE_API_KEY=sk-ant-...                 # CHỈ dùng trong Edge Functions, không bao giờ để frontend

# ─── EMAIL ────────────────────────────────────────────────────
SENDGRID_API_KEY=SG...

# ─── ZALO ─────────────────────────────────────────────────────
ZALO_ZNS_SECRET=...                       # Sau khi được duyệt ZNS

# ─── ANALYTICS ────────────────────────────────────────────────
GA_MEASUREMENT_ID=G-XXXXXXXXXX
SENTRY_DSN=https://...@sentry.io/...

# ─── PAYMENT (giai đoạn 2) ────────────────────────────────────
VNPAY_HASH_SECRET=...
VNPAY_TMN_CODE=...

# ─── VERCEL (điền trong Vercel Dashboard, không cần file này) ──
# Vercel tự inject các biến này khi deploy
